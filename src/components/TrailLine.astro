---
interface Props {
  variant?: 'hero' | 'services' | 'about' | 'divider' | 'projects';
  class?: string;
}

const { variant = 'hero', class: className = '' } = Astro.props;

const viewBoxes: Record<string, string> = {
  hero: '0 0 1200 420',
  services: '0 0 640 1400',
  about: '0 0 900 260',
  divider: '0 0 984 70',
  projects: '0 0 1184 420',
};

const paths: Record<string, string> = {
  hero: 'M -40,280 C 140,80 260,360 460,200 S 760,60 900,240 1040,140 1240,220',
  services: 'M 60,40 C 240,160 20,320 220,460 S 460,600 240,760 500,900 340,1060 620,1200 460,1360',
  about: 'M -20,140 C 160,60 260,240 440,140 S 720,60 920,160',
  divider: 'M0,35 C 165,8 330,62 492,35 C 654,8 819,62 984,35',
  projects: 'M0,40 C 220,140 380,10 592,110 C 804,210 940,40 1184,140',
};
---

<svg
  class={className}
  viewBox={viewBoxes[variant]}
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d={paths[variant]}
    fill="none"
    stroke="#2F6E63"
    stroke-width="3"
    stroke-linecap="round"
    stroke-dasharray="2 16"
    opacity="0.45"
  />
  <path
    d={paths[variant]}
    fill="none"
    stroke="#E7A335"
    stroke-width="3"
    stroke-linecap="round"
    stroke-dasharray="2 16"
    stroke-dashoffset="9"
    opacity="0.35"
  />
</svg>
