---
import { getEntry } from 'astro:content';

interface Props {
  size?: 'compact' | 'full';
}

const { size = 'full' } = Astro.props;
const site = await getEntry('site', 'main');
const { contactHeading, contactBody, email, instagramUrl, telegramUrl } = site!.data;

const headingClass = size === 'full' ? 'text-4xl sm:text-5xl' : 'text-3xl sm:text-4xl';
const sectionPadding = size === 'full' ? 'py-24' : 'py-16';
---

<section class={`${sectionPadding} px-6`}>
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-6 rounded-[2.5rem] bg-teal px-8 py-16 text-center text-ivory">
    <h2 class={`font-display font-bold ${headingClass}`}>{contactHeading}</h2>
    <p class="max-w-xl font-sans text-lg leading-relaxed text-ivory/85">{contactBody}</p>
    <a
      href={`mailto:${email}`}
      class="rounded-full bg-amber px-8 py-3 font-display font-semibold text-ink transition-transform hover:scale-105"
    >
      {email}
    </a>
    {(instagramUrl || telegramUrl) && (
      <div class="flex items-center gap-3">
        {instagramUrl && (
          <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-ivory/15 transition-colors hover:bg-amber hover:text-ink"
          >
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="3" width="18" height="18" rx="6" />
              <circle cx="12" cy="12" r="4.2" />
              <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />
            </svg>
          </a>
        )}
        {telegramUrl && (
          <a
            href={telegramUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Telegram"
            class="flex h-10 w-10 items-center justify-center rounded-full bg-ivory/15 transition-colors hover:bg-amber hover:text-ink"
          >
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M21 4 3 11.2l6 2.1M21 4 15.5 20l-6.5-6.7M21 4 9 13.3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        )}
      </div>
    )}
  </div>
</section>
