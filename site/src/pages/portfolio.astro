---
import Layout from '../layouts/Layout.astro';
import TrailLine from '../components/TrailLine.astro';
import { getEntry } from 'astro:content';

const site = await getEntry('site', 'main');
const portfolio = await getEntry('portfolio', 'main');
const {
  eyebrow,
  heading,
  subhead,
  experienceHeading,
  experience,
  projectsHeading,
  projectsSubhead,
  projects,
  educationHeading,
  educationBody,
  ctaHeading,
  ctaBody,
  ctaEmail,
  githubUrl,
} = portfolio!.data;

const title = `${heading} — ${site!.data.name}`;
const description = subhead;
---

<Layout title={title} description={description}>
  <section class="px-6 pt-16 pb-4 text-center">
    <div class="mx-auto max-w-2xl">
      <span class="inline-block rounded-full bg-sand px-4 py-1.5 font-display text-sm font-medium text-amber-deep">
        {eyebrow}
      </span>
      <h1 class="mt-6 font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">{heading}</h1>
      <p class="mt-6 font-sans text-lg leading-relaxed text-ink-soft">{subhead}</p>
    </div>
  </section>

  <div class="mx-auto max-w-3xl px-6">
    <TrailLine variant="divider" class="h-12 w-full" />
  </div>

  <section class="bg-sage px-6 py-16">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display text-3xl font-bold text-ink">{experienceHeading}</h2>
      <div class="mt-9 flex flex-col gap-5">
        {experience.map((entry, index) => (
          <div class="grid grid-cols-[3.5rem_1fr] gap-6 rounded-[1.75rem] bg-ivory p-7">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-ink font-display text-sm font-bold text-ivory">
              {String(index + 1).padStart(2, '0')}
            </div>
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h3 class="font-display text-xl font-bold text-ink">{entry.role} · {entry.company}</h3>
                <span class="whitespace-nowrap font-sans text-sm font-semibold text-amber-deep">{entry.period}</span>
              </div>
              <ul class="mt-3 list-disc space-y-1.5 pl-5">
                {entry.bullets.map((bullet) => (
                  <li class="font-sans text-[15.5px] leading-relaxed text-ink-soft">{bullet}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-6 py-20">
    <TrailLine
      variant="projects"
      class="pointer-events-none absolute inset-x-6 top-32 -z-10 h-[420px] opacity-60"
    />
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center font-display text-3xl font-bold text-ink">{projectsHeading}</h2>
      <p class="mt-3 text-center font-sans text-ink-soft">{projectsSubhead}</p>
      <div class="mt-11 flex flex-wrap gap-6">
        {projects.map((project, index) => {
          const bg = index % 2 === 0 ? 'bg-sage' : 'bg-sand';
          const offset = index % 2 === 1 ? 'sm:translate-y-5' : '';
          return (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class={`block flex-1 basis-72 rounded-[2rem] p-8 text-ink transition-transform hover:scale-[1.02] ${bg} ${offset}`}
            >
              <h3 class="font-display text-lg font-bold">{project.title} →</h3>
              <p class="mt-2.5 font-sans text-sm leading-relaxed text-ink-soft">{project.description}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="bg-sand px-6 py-16">
    <div class="mx-auto max-w-2xl">
      <h2 class="font-display text-2xl font-bold text-ink">{educationHeading}</h2>
      <div class="mt-5 flex flex-col gap-3">
        {educationBody.map((paragraph) => (
          <p class="font-sans leading-relaxed text-ink-soft" set:html={paragraph} />
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-xl">
      <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">{ctaHeading}</h2>
      <p class="mt-4 font-sans text-lg leading-relaxed text-ink-soft">{ctaBody}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href={`mailto:${ctaEmail}`}
          class="rounded-full bg-amber px-8 py-3 font-display font-semibold text-ink transition-transform hover:scale-105"
        >
          {ctaEmail}
        </a>
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border-2 border-ink px-8 py-3 font-display font-semibold text-ink transition-colors hover:bg-ink hover:text-ivory"
        >
          GitHub
        </a>
      </div>
    </div>
  </section>
</Layout>
