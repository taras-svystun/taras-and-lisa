---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const site = await getEntry('site', 'main');
const { name, aboutHeading, aboutBody, aboutPhotoAlt } = site!.data;

const photoFiles = import.meta.glob('/src/assets/taras-and-lisa.*', { eager: true, query: '?url', import: 'default' });
const photoUrl = Object.values(photoFiles)[0] as string | undefined;

const title = `${aboutHeading} — ${name}`;
const description = aboutBody[0];
const photoMask = 'border-radius: 42% 58% 46% 54% / 48% 42% 58% 52%;';
---

<Layout title={title} description={description}>
  <section class="px-6 py-20">
    <div class="mx-auto grid max-w-5xl items-center gap-12 lg:grid-cols-2">
      <div class="relative mx-auto w-full max-w-md lg:order-2">
        {photoUrl ? (
          <img
            src={photoUrl}
            alt={aboutPhotoAlt}
            class="aspect-3/4 w-full object-cover shadow-xl"
            style={photoMask}
          />
        ) : (
          <div
            class="flex aspect-3/4 w-full items-center justify-center bg-sand text-center font-display text-ink-soft shadow-xl"
            style={photoMask}
          >
            Photo coming soon
          </div>
        )}
      </div>
      <div class="lg:order-1">
        <h1 class="font-display text-4xl font-bold text-teal sm:text-5xl">{aboutHeading}</h1>
        <div class="mt-6 flex flex-col gap-5">
          {aboutBody.map((paragraph) => (
            <p class="font-sans text-lg leading-relaxed text-ink-soft">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
