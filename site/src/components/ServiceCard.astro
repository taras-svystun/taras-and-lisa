---
interface Props {
  id: string;
  title: string;
  description: string;
  index: number;
}

const { id, title, description, index } = Astro.props;
const bg = index % 2 === 0 ? 'bg-sage' : 'bg-sand';
const num = String(index + 1).padStart(2, '0');
---

<article id={id} class={`${bg} rounded-[2rem] p-8 shadow-sm`}>
  <span class="font-display text-sm font-semibold text-amber-deep">{num}</span>
  <h3 class="mt-3 font-display text-xl font-bold text-ink">{title}</h3>
  <p class="mt-3 font-sans leading-relaxed text-ink-soft">{description}</p>
</article>
